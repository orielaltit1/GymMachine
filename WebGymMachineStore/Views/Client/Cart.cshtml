@using Models;
@model ShoppingCartViewModel;

@{
    ViewData["Title"] = "Cart";
    Layout = "~/Views/Shared/ClientMasterPage.cshtml";
}
<link href="~/stylesheets/cartpage.css" rel="stylesheet" />
<main class="page">
    <section class="cart">
        <h2>Shopping Cart</h2>
        @foreach(GymMachine gymMachine in Model.Machines)
        {
            <div class="item">
            <div class="img">@gymMachine.MachineImage</div>
            <div class="info">
                <h4>@gymMachine.MachineName</h4>
                <p>@gymMachine.MachineDescription</p>
            </div>
                <div class="controls">
                    <span class="price">@gymMachine.MachinePrice$</span>
                    <div class="qty-box">
                        <button onclick="updateQty(this, -1)">−</button>
                        <span class="qty">1</span>
                        <button onclick="updateQty(this, 1)">+</button>
                    </div>
                </div>
            </div> 
        }

            
        
    </section>

    <aside class="summary">
        <h3>Order Summary</h3>
        <div class="line">
            <span>Total</span>
            <span id="total">$200</span>
        </div>
        <button class="checkout">CHECK OUT</button>
        <button class="continue">Continue Shopping</button>
    </aside>
</main>

