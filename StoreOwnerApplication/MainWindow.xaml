<Window x:Class="StoreOwnerApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StoreOwnerApplication"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        BorderBrush="Transparent"
        >

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- תוכן באמצע -->
        <Grid x:Name="MainContent">
            <Frame x:Name="ContentFrame"
               NavigationUIVisibility="Hidden"
               HorizontalAlignment="Center" />
        </Grid>

        <!-- רקע כהה -->
        <Grid x:Name="Overlay"
          Background="#80000000"
          Visibility="Collapsed"
          Panel.ZIndex="1"/>

        <!-- SIDEBAR -->
        <Border x:Name="MenuPanel"
            Width="60"
            Background="Gray"
            HorizontalAlignment="Left"
            Panel.ZIndex="2">

            <StackPanel>

                <!-- Hamburger -->
                <Button Content="☰"
                    FontSize="20"
                    Foreground="White"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ThreeLines_Click"/>

                <!-- MENU ITEM -->
                <Button x:Name="HomeBtn" Style="{StaticResource MenuButtonStyle}" Click="Button_Click">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Image Source="/Images/HomeIcon.png" Width="20" Margin="9,0,8,0" />
                        <TextBlock Text="Home"
                           Margin="20,0,0,0"
                           Visibility="Visible"/>
                    </StackPanel>
                </Button>
                <Button x:Name="MachinesBtn" Style="{StaticResource MenuButtonStyle}" Click="Button_Click_2">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Image Source="/Images/ListIcon.png" Width="20" Margin="9,0,10,0"/>
                        <TextBlock Text="Machines"
                            Margin="20,0,0,0"
                            Visibility="Visible">
                        </TextBlock>
                    </StackPanel>
                </Button>
                <Button x:Name="Client_btn" Style="{StaticResource MenuButtonStyle}" Click="Client_btn_Click">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Image Source="/Images/ClientIcon.png" Width="20" Margin="9,0,8,0" />

                        <TextBlock Text="ClientCatalog"
                           Margin="20,0,0,0"
                           Visibility="Visible"/>
                    </StackPanel>
                </Button>
                <Button x:Name="Logout_btn" Style="{StaticResource MenuButtonStyle}" Click="Logout_btn_Click">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <Image Source="/Images/LogoutIcon.png" Width="20" Margin="9,0,8,0" />

                        <TextBlock Text="ClientCatalog"
                           Margin="20,0,0,0"
                           Visibility="Visible"/>
                    </StackPanel>
                </Button>

                <TextBlock Margin="20,220,0,0">
                    <Hyperlink Foreground="White" x:Name="ExitBtn" Click="ExitBtn_Click" FontSize="10" TextDecorations="None" >
                        <Image Source="/Images/XButton.png" Width="20"/>

                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Border>

    </Grid>


</Window>
