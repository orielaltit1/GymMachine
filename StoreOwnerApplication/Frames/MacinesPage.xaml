<UserControl x:Class="StoreOwnerApplication.Frames.MacinesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
             mc:Ignorable="d" 
             Height="450" Width="800">

    <Grid Background="#F5F5F5" Margin="60,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gym Machines" FontWeight="Black" FontSize="36" 
                   HorizontalAlignment="Center" Margin="0,20,0,10" Foreground="#333"/>

        <Grid Grid.Row="1" Margin="30,10,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="+ Add Machine" Background="#007ACC" Foreground="White" 
                    FontWeight="Bold" Padding="50, 10"
                    Click="AddMachine_Click"/>

            <TextBlock x:Name="CountTextBlock"
               Foreground="Black"
               FontSize="20"
               FontWeight="Bold"
               Visibility="Collapsed"
               Margin="10, 10,10 ,10"
               Text="Loading..."
               />
        </Grid>
        
            <ListView x:Name="MachinesListView" Grid.Row="2" Margin="30,10" 
                  BorderThickness="0" Background="Transparent">
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="5" Margin="0,2" Padding="5" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="550"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Machine.MachineName}" FontWeight="Bold" FontSize="16" Margin="9, 2,0 ,20" />
                            </StackPanel>

                            <Button x:Name="Delete_btn" Grid.Column="1" Content="Delete" Background="#FF4444" Foreground="White" 
                                    Padding="10,5" BorderThickness="0"
                                    Click="Delete_btn_Click_1"/>
                            <TextBlock Text="{Binding Brand.BrandName}" Foreground="Gray" FontSize="12" Margin="9,34,0,6" d:LayoutOverrides="Width"/>
                            <TextBlock Text="{Binding Machine.MachinePrice}" Foreground="Gray" FontSize="12" Margin="90,34,286,-3" Width="84"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            
        </ListView>
            <Frame x:Name="MainFrame"
               Grid.Row="0"
               Grid.RowSpan="3"
               Background="White"
               NavigationUIVisibility="Hidden"
               Visibility="Collapsed"
               Panel.ZIndex="10"/>
        
    </Grid>
</UserControl>