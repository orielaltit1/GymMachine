<Page x:Class="StoreOwnerApplication.Frames.NewMachine"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
      mc:Ignorable="d" FontSize="25"
      d:DesignHeight="450" d:DesignWidth="630"
      Title="NewMachine" Background="#F5F5F5">

    <Grid>

        <!-- כפתור חזור -->
        <Button x:Name="goBack_btn"
                Width="30"
                Height="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="15"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="goBack_btn_Click">
            <Image Source="/Images/GoBackIcon.png" />
        </Button>

        <!-- תוכן מרכזי -->
        <StackPanel Width="350"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    >

            <TextBlock Text="Add Machine"
                       FontSize="36"
                       FontWeight="Black"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       Foreground="#333"/>

            <!-- Machine Name -->
            <Label Content="Machine Name"
                   FontSize="18"
                   FontWeight="Bold"/>
            <TextBox Height="30"
                     FontSize="16"/>

            <!-- Machine Price -->
            <Label Content="Machine Price"
                   FontSize="18"
                   FontWeight="Bold"/>
            <TextBox Height="30"
                     FontSize="16"/>

            <!-- Machine Description -->
            <Label Content="Machine Description"
               FontSize="18"
               FontWeight="Bold"/>
            <TextBox Height="30"
                FontSize="16"/>

            <!-- Machine Image -->
            <Label Content="Machine Image"
                FontSize="18"
                FontWeight="Bold"/>
            <TextBox Height="30"
                FontSize="16"/>
            
            <!-- Machine Brand -->
            <Label Content="Machine Brand"
                   FontSize="18"
                   FontWeight="Bold"/>
            <ComboBox x:Name="BrandComboBox"
                      Height="30"
                      FontSize="16"/>

            <!-- Save Button -->
            <Button x:Name="Save_Btn" 
                    Click="Save_Btn_Click"
                    Content="Save"
                    Height="45"
                    Margin="0,20,0,0"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Cursor="Hand"/>

        </StackPanel>

    </Grid>

</Page>
