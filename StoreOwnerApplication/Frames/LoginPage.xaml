<UserControl x:Class="StoreOwnerApplication.Frames.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
             mc:Ignorable="d" 
             Height="450" Width="740">


    <UserControl.Resources>
        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="FontSize" Value="15"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>    
    
    <Grid Background="White">
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="LOGIN" FontSize="42" FontWeight="Heavy" Margin="0,0,0,20" Foreground="#333"/>

            <!-- הודעת שגיאה -->
            <TextBlock x:Name="EmailError"
               Foreground="Red"
               FontSize="12"
               Visibility="Collapsed" />

            <TextBlock Text="Email" FontWeight="DemiBold"/>
            <TextBox  x:Name="EmailTextBox" Height="19"  Margin="0, 5, 0 , 0"/>

            <!-- הודעת שגיאה -->
            <TextBlock x:Name="PasswordError"
               Foreground="Red"
               FontSize="12"
               Visibility="Collapsed" Margin="0, 40, 0 ,-40"/>

            <TextBlock Text="Password" FontWeight="DemiBold" Margin="0, 40, 0 ,0"/>
            <PasswordBox x:Name="PasswordBox" Height="19" Margin="0, 5, 0 , 0"/>

            <Button x:Name="button_Login" Content="Submit" Height="40" Margin="0,15,0,0" 
                    Foreground="White" FontWeight="Bold" Cursor="Hand" Style="{StaticResource GreenButtonStyle}" Click="button_Login_Click"/>

            <TextBlock x:Name="SubmitError"
               Foreground="Red"
               FontSize="12"
               Visibility="Collapsed" Margin="0,5,0,0"/>

        </StackPanel>
    </Grid>
</UserControl>
