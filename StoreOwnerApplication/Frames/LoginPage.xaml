<UserControl x:Class="StoreOwnerApplication.Frames.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas>
        <TextBox x:Name="EmailLogin" Canvas.Left="31" Canvas.Top="112" HorizontalAlignment="Center" VerticalAlignment="Top" Width="287" Height="27"/>
        <Label Canvas.Left="22" Canvas.Top="14" Height="72" Width="185" FontSize="50" FontWeight="Bold">LOGIN</Label>
        <Button x:Name="button_Login" Content="Submit" Canvas.Left="31" Canvas.Top="208" Height="24" Width="287" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Label x:Name="label" Content="Email" Canvas.Left="29" Canvas.Top="80" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20"/>
        <TextBox x:Name="EmailLogin_Copy" Canvas.Left="31" Canvas.Top="170" Width="287" Height="27" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Label x:Name="label_Copy" Content="Password" Canvas.Left="29" Canvas.Top="137" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"/>
    </Canvas>
</UserControl>
