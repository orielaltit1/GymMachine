<UserControl x:Class="StoreOwnerApplication.Frames.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
             mc:Ignorable="d" 
             Height="450" Width="740">
    <Canvas>
        <Label Canvas.Left="37" Canvas.Top="11" Height="84" Width="232" FontSize="50" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center">LOGIN</Label>
        <Label x:Name="label" Content="Email" Canvas.Left="34" Canvas.Top="100" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20" Height="43" Width="72"/>
        <TextBox x:Name="EmailLogin" Canvas.Left="37" Canvas.Top="135" HorizontalAlignment="Left" VerticalAlignment="Center" Width="361" Height="32"/>
        <Label x:Name="label_Copy" Content="Password" Canvas.Left="34" Canvas.Top="190" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Height="43" Width="116"/>
        <TextBox x:Name="PassLogin" Canvas.Left="37" Canvas.Top="225" Width="361" Height="31" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Button x:Name="button_Login" Content="Submit" Canvas.Left="37" Canvas.Top="280" Height="28" Width="361" HorizontalAlignment="Left" VerticalAlignment="Center" Click="button_Login_Click"/>
    </Canvas>
</UserControl>
