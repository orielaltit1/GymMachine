<Window x:Class="StoreOwnerApplication.Frames.NewMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StoreOwnerApplication.Frames"
        mc:Ignorable="d"
        Title="NewMachineWindow" 
        FontSize="15"
        Height="500" 
        Width="730"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="15"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Margin="15">

        <!-- שורות כלליות -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- כפתור חזור -->
        <Button x:Name="goBack_btn"
            Width="30"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Background="Transparent"
            BorderBrush="Transparent"
            Click="goBack_btn_Click">
            <Image Source="/Images/GoBackIcon.png" />
        </Button>
        <!-- כותרת -->
        <TextBlock Grid.Row="0"
                   Text="Add Machine"
                   FontSize="30"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"
                   Foreground="#333"/>

        <!-- אזור מרכזי -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="White"
        
                CornerRadius="20"
                Padding="40"
                HorizontalAlignment="Left"
                Margin="24,20,0,20" Grid.Column="2">
                
                <!-- צד שמאל -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">

                <!--Machine Name-->
                <TextBlock Text="Machine Name" FontWeight="Bold"/>
                <TextBox x:Name="MachineNameTextBox"
                         Height="28"
                         Margin="0,3,0,8"/>

                <!--Machine Price-->
                <TextBlock Text="Machine Price" FontWeight="Bold"/>
                <TextBox x:Name="MachinePriceTextBox"
                         Height="28"
                         Margin="0,3,0,8"/>

                <!--Machine Description-->
                <TextBlock Text="Description" FontWeight="Bold"/>
                <TextBox x:Name="MachineDescriptionTextBox"
                         Height="50"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Margin="0,3,0,8"/>

                <!--Machine Brand-->
                <TextBlock Text="Machine Brand" FontWeight="Bold"/>
                <ComboBox x:Name="BrandComboBox"
                          DisplayMemberPath="BrandName"
                          SelectedValuePath="BrandId"
                          Height="30"
                          Margin="0,3,0,0"/>

            </StackPanel>
            </Border>
                
            <Border Background="White"
                    
                        CornerRadius="20"
                        Padding="40"
                        HorizontalAlignment="Left"
                        Margin="24,20,0,20" Grid.Column="2">
                
                <!-- צד ימין -->
                <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                    <TextBlock Text="Machine Image"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                    <!--Machine Image-->
                    <Image x:Name="MachineImagePreview"
                       Height="140"
                       Width="200"
                       Stretch="Uniform"
                       Margin="0,0,0,10"/>

                    <Button x:Name="ChooseImage" Content="Choose Image"
                    Style="{StaticResource GreenButtonStyle}" Click="ChooseImage_Click"/>

                </StackPanel>
            </Border>

        </Grid>
        <!-- Save -->
        <Button Grid.Row="2"
                x:Name="Save_Btn"
                Content="Save"
                Height="50"
                Width="300"
                Style="{StaticResource GreenButtonStyle}" Click="Save_Btn_Click"/>

    </Grid>
</Window>
